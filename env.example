# ╔══════════════════════════════════════════════════════════════════╗
# ║   Digital Manufacturing Academy — Environment Variables Template ║
# ║   Copy this file → .env  and fill in your real values.          ║
# ║   NEVER commit .env to a public or shared repository.           ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── REQUIRED ─────────────────────────────────────────────────────────────────
# Signs and verifies all JWT session cookies (dma_token).
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING_MIN_32_CHARS

# ── SERVER ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── ADMIN SEED PASSWORD ───────────────────────────────────────────────────────
# Used ONCE on first boot to create the super_admin and admin accounts.
# Generate: node -e "console.log(require('crypto').randomBytes(20).toString('hex'))"
# Change all admin passwords immediately after first login.
# NEVER use a simple or publicly known value here.
SEED_ADMIN_PASSWORD=REPLACE_WITH_A_STRONG_RANDOM_PASSWORD

# ── DATABASE ──────────────────────────────────────────────────────────────────
# Default: flat-file JSON store (db_state.json) — no setup required for dev.
# Set MYSQL_DATABASE_URL to switch to MySQL via Prisma ORM.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# MYSQL_DATABASE_URL=mysql://DB_USER:DB_PASSWORD@DB_HOST:3306/DB_NAME

# ── SMTP — HOSTINGER MAIL ─────────────────────────────────────────────────────
SMTP_USER=info@digitalmanufacturing.academy
SMTP_PASS=YOUR_EMAIL_PASSWORD_HERE
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
EMAIL_FROM_NAME=DMA Academy

# ── AI TUTOR ─────────────────────────────────────────────────────────────────
# Powers the in-app DMA AI Assistant via Google Gemini.
# Free key: https://aistudio.google.com/app/apikey
# Without this the AI tutor runs in demo/mock mode (still functional).
# GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
