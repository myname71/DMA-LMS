# ╔══════════════════════════════════════════════════════════════════╗
# ║   Digital Manufacturing Academy — Environment Variables Template ║
# ║   Copy this file → .env  and fill in your real values.          ║
# ║   NEVER commit .env to a public or shared repository.           ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── REQUIRED ─────────────────────────────────────────────────────────────────
# Signs and verifies all JWT session cookies (dma_token).
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING_MIN_32_CHARS

# ── SERVER ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── DATABASE ──────────────────────────────────────────────────────────────────
# Default: flat-file JSON store (db_state.json) — no setup required.
# Set MYSQL_DATABASE_URL to switch to MySQL via Prisma ORM.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Hostinger: hPanel → Databases → MySQL Databases → Connection Details
# MYSQL_DATABASE_URL=mysql://u858137765_DMA:YOUR_DB_PASSWORD@srv.hostinger.com:3306/u858137765_DMA

# ── SMTP — HOSTINGER MAIL ─────────────────────────────────────────────────────
# Sender address — must match an active Hostinger mailbox.
SMTP_USER=info@digitalmanufacturing.academy

# App password from Hostinger hPanel → Emails → Manage → Change Password
SMTP_PASS=YOUR_EMAIL_PASSWORD_HERE

# Hostinger outgoing SMTP server
SMTP_HOST=smtp.hostinger.com

# Port 465 → SSL/TLS  (recommended — secure: true)
# Port 587 → STARTTLS (alternative — secure: false + requireTLS: true)
SMTP_PORT=465

# Display name shown in recipients' inboxes
EMAIL_FROM_NAME=DMA Academy

# ── AI TUTOR ─────────────────────────────────────────────────────────────────
# Powers the in-app DMA AI Assistant via Google Gemini.
# Free key: https://aistudio.google.com/app/apikey
# Without this the AI tutor runs in demo/mock mode (still functional).
# GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── ADMIN SEED (reference only — seeded automatically on first boot) ──────────
# SUPER_ADMIN_EMAIL=pandoratecllc@gmail.com
# ADMIN_EMAIL=digitalmfg.2026@gmail.com
# DEFAULT_ADMIN_PASSWORD=Dmamfg.2026
